{
  "manifest_version": 3,
  "name": "Puklerzniczek karłowaty",
  "version": "1.0.0",
  "description": "Creates nice graph of opened tabs",
  "icons": {
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "permissions": [
    "tabs",
    "storage"
  ],
  "background": {
    "service_worker": "scripts/service.js"
  }
}